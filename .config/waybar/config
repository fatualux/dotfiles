{
    "layer": "top",
    "position": "top",
    "height": 33,
    "width": 800,
    "margin": "3, 0, 2, 0",
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad"],
    "modules-center": ["keyboard-state",],
    "modules-right": ["idle_inhibitor", "backlight", "pulseaudio", "cpu", "memory", "custom/gpu", "temperature", "battery", "battery#bat2", "custom/pacman", "network", "netspeed", "tray", "bluetooth", "clock", "custom/power"],
    // Modules configuration
    // "sway/workspaces": {
    //     "disable-scroll": true,
    //     "all-outputs": true,
    //     "warp-on-scroll": false,
    //     "format": "{name}: {icon}",
    //     "format-icons": {
    //         "1": "яДа",
    //         "2": "яЙи",
    //         "3": "яДб",
    //         "4": "яЖ╝",
    //         "5": "яБ╡",
    //         "urgent": "яБк",
    //         "focused": "яЖТ",
    //         "default": "яДС"
    //     }
    // },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": ""
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "Europe/Rome",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": " яЛЫ {usage}%",
        "on-click": "alacritty -e btop"
    },
    "memory": {
        "format": " яГЙ {}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": " {icon} {temperatureC}┬░C",
        "format": " {icon} {temperatureC}┬░C",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": " {icon} {percent}%",
        "format-icons": ["яЖЖ", "яЖЖ", "яЖЖ", "яБВ", "яБВ", "яБВ", "яЖЕ", "яЖЕ", "яЖЕ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": " {icon} {capacity}% ",
        "interval": 1,
        "format-charging": " яЧз {capacity}%",
        "format-plugged": " яЗж {capacity}%",
        "format-alt": " {icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
      "bat": "BAT2"
    },
    "network": {
        "interface": "wlan0",
        "format-wifi": "яЗл  {essid} ({signalStrength}%) -  яБг {bandwidthDownBytes} яБв {bandwidthUpBytes}",
        "interval": 5,
        "format-ethernet": "яЮЦ  {ipaddr}/{cidr} ",
        "tooltip-format": "яЮЦ  {ifname} via {gwaddr} ",
        "format-linked": "яЮЦ  {ifname} (No IP) ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/pacman": {
        "format": "{}",
        "interval": 3600,                     // every hour
        "exec": "echo ''яДо $(checkupdates | wc -l)",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "on-click": "dunstify 'Packages Update' && alacritty -e trizen -Syu | wc -l;  pkill -SIGRTMIN+8 waybar", // update system,
        "signal": 8
    },
    "bluetooth": {
        "format-on": "яКФ - ON",
        "format-disabled": "яКФ - OFF",
        "interval": 3,
        "format-connected": "яКФ {device_alias}",
        "format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
        // "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
        "on-click": "blueberry"
    },
    "custom/power": {
      "format": "тП╗",
      "on-click": "$HOME/.config/waybar/custom/poweroff.sh",
      "tooltip": false
    },
    "custom/gpu": {
      "exec": "DEVICE=$(nvidia-smi --query-gpu=name --format=csv,noheader,nounits) && PERCENTAGE=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits | awk '{printf(\"%d%%\", $1)}') && TEMP=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits | awk '{printf(\"%d┬░C\", $1)}') && echo $DEVICE - $PERCENTAGE - $TEMP",
      "format-icons": ["яФ╕", "яФ┐"],
      "format": "{icon} {}",
      "return-type": "",
      "on-click": "nvidia-settings",
      "interval": 1
    },
}
